generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  phone     String   @unique
  name      String?
  timezone  String   @default("Europe/Moscow")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  services      Service[]
  appointments  Appointment[]
  workingHours  WorkingHours[]
  timeOffs      TimeOff[]
  devices       Device[]
  storefront    Storefront?
  subscription  Subscription?
  refreshTokens RefreshToken[]
  broadcasts    Broadcast[]
  clients       Client[]
}

model OtpCode {
  id        String    @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([phone])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Device {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Service {
  id           String   @id @default(cuid())
  userId       String
  name         String
  durationMin  Int
  priceKopecks Int
  bufferMin    Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments Appointment[]
}

model Client {
  id           String    @id @default(cuid())
  userId       String
  phone        String
  name         String
  telegramId   String?
  consentGiven Boolean   @default(false)
  consentAt    DateTime?
  notes        String?
  tags         String[]
  isSubscribed Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@unique([userId, phone])
}

model Appointment {
  id        String            @id @default(cuid())
  userId    String
  clientId  String
  serviceId String
  startsAt  DateTime
  endsAt    DateTime
  status    AppointmentStatus @default(pending)
  notes     String?
  source    String            @default("master")
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  client  Client   @relation(fields: [clientId], references: [id])
  service Service  @relation(fields: [serviceId], references: [id])
  payment Payment?
}

enum AppointmentStatus {
  pending
  confirmed
  cancelled
  completed
  no_show
}

model WorkingHours {
  id        String   @id @default(cuid())
  userId    String
  dayOfWeek Int
  startTime String
  endTime   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dayOfWeek])
}

model TimeOff {
  id        String   @id @default(cuid())
  userId    String
  startsAt  DateTime
  endsAt    DateTime
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Payment {
  id            String        @id @default(cuid())
  appointmentId String        @unique
  providerRef   String        @unique
  provider      String
  amountKopecks Int
  status        PaymentStatus @default(pending)
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id])
}

enum PaymentStatus {
  pending
  paid
  refunded
  failed
}

model Broadcast {
  id          String          @id @default(cuid())
  userId      String
  text        String
  tags        String[]
  status      BroadcastStatus @default(draft)
  scheduledAt DateTime?
  sentAt      DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum BroadcastStatus {
  draft
  scheduled
  sending
  sent
  cancelled
}

model Storefront {
  id             String   @id @default(cuid())
  userId         String   @unique
  slug           String   @unique
  title          String
  description    String?
  photoUrl       String?
  isActive       Boolean  @default(true)
  requirePayment Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Subscription {
  id               String             @id @default(cuid())
  userId           String             @unique
  plan             String             @default("free")
  status           SubscriptionStatus @default(active)
  expiresAt        DateTime?
  revenuecatUserId String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum SubscriptionStatus {
  active
  expired
  cancelled
}
