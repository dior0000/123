{
  "expo": {
    "name": "PocketBiz",
    "slug": "pocketbiz",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "pocketbiz",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "com.pocketbiz.app",
      "supportsTablet": false,
      "associatedDomains": [
        "applinks:book.pocketbiz.app",
        "webcredentials:book.pocketbiz.app"
      ],
      "infoPlist": {
        "NSCameraUsageDescription": "Нужна для фото профиля",
        "NSPhotoLibraryUsageDescription": "Нужна для загрузки фото профиля"
      }
    },
    "android": {
      "package": "com.pocketbiz.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": ["NOTIFICATIONS", "CAMERA", "READ_EXTERNAL_STORAGE"],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "book.pocketbiz.app",
              "pathPrefix": "/"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "server",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#ffffff"
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "organization": "TODO-sentry-org",
          "project": "pocketbiz-mobile"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "TODO-replace-with-eas-project-id"
      }
    }
  }
}
